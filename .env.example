# Copy this file to .env and replace the value with your own API keys.
# Use OPENAI_API_KEY for OpenAI, or ANTHROPIC_KEY for Anthropic.
OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_KEY=your_anthropic_api_key_here
VITE_ODDS_API_KEY=your_the_odds_api_key_here

# Optional DFS proxy providers for Vercel dev/deploy.
# PrizePicks can use APIFY_TOKEN with the built-in actor below, or PRIZEPICKS_PROXY_URL.
APIFY_TOKEN=your_apify_token_here
# PRIZEPICKS_PROXY_URL=https://your-prizepicks-provider.example/json

# Underdog needs either a direct provider URL or your Apify actor name plus APIFY_TOKEN.
# UNDERDOG_PROXY_URL=https://your-underdog-provider.example/json
# UNDERDOG_APIFY_ACTOR=your-apify-username~your-underdog-actor
