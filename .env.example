# Copy to .env.local for local development (never commit real keys).
# Vite exposes only VITE_* variables to the browser — use server-side env for secrets when possible.

# Required for sportsbook line comparison (The Odds API)
VITE_ODDS_API_KEY=your_the_odds_api_key_here

# Required for SportsDataIO MLB enrichment (https://sportsdata.io)
# Sent as the Ocp-Apim-Subscription-Key header on /api/sportsdata/v3/mlb requests
VITE_SPORTSDATA_API_KEY=your_sportsdataio_mlb_key_here

# Optional — reserved for future StatMuse enrichment
VITE_STATMUSE_API_KEY=your_statmuse_api_key_here

# Optional DFS proxy providers when direct PrizePicks/Underdog fetches are blocked (CORS / geo)
# Local dev: run `npm run proxy` in a second terminal, then use:
# VITE_PRIZEPICKS_PROXY_URL=http://localhost:4000/api/prizepicks/mlb
VITE_PRIZEPICKS_PROXY_URL=https://your-prizepicks-provider.example/json
VITE_UNDERDOG_PROXY_URL=https://your-underdog-provider.example/json
# VITE_PRIZEPICKS_PROXY=https://your-prizepicks-provider.example/json
# VITE_UNDERDOG_PROXY=https://your-underdog-provider.example/json

# Server-side only (Vercel / Node) — not exposed to the browser bundle
APIFY_TOKEN=your_apify_token_here
# UNDERDOG_APIFY_ACTOR=your-apify-username~your-underdog-actor

# Legacy names still supported by the dev proxy if set server-side:
# PRIZEPICKS_PROXY_URL=
# UNDERDOG_PROXY_URL=
# ODDS_API_KEY=
# SPORTSDATA_API_KEY=
