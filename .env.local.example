# Copy to .env.local and paste your real keys (never commit .env.local).
# Restart `npm run dev` after saving.

# The Odds API — optional sportsbook line comparison (NOT required for PrizePicks/Underdog picks)
VITE_ODDS_API_KEY=your_the_odds_api_key_here

# SportsDataIO MLB subscription — season stat projections (recommended)
VITE_SPORTSDATA_API_KEY=your_sportsdataio_mlb_key_here

# Optional external proxies if PrizePicks/Underdog direct fetch is blocked
# VITE_PRIZEPICKS_PROXY_URL=https://your-provider.example/prizepicks
# VITE_UNDERDOG_PROXY_URL=https://your-provider.example/underdog
